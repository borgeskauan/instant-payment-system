          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_commit[1m])) + sum(rate(pg_stat_database_xact_rollback[1m]))",
          "legendFormat": "transactions/s",
          "refId": "B"
        }
      ],
      "title": "Postgres cache and transaction activity",
      "type": "timeseries"
